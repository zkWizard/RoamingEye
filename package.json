{
  "name": "roamingeye",
  "version": "1.1.0",
  "description": "A high-fidelity, open-source 3D Earth you can roam from a satellite's-eye view.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/check-bundle-size.mjs",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:engines": "playwright test --project=webkit --project=firefox",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:soak": "playwright test --config playwright.soak.config.ts",
    "agents:run": "node scripts/run-agent-fleet.mjs",
    "catalog:check": "node scripts/agents/qa-release.mjs",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run catalog:check && npm run build",
    "verify:full": "npm run verify && npm run test:e2e",
    "deploy": "node scripts/deploy.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "gifenc": "^1.0.3",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
